name = "channel-messenger"
main = ".svelte-kit/cloudflare/_worker.js"
compatibility_date = "2025-12-01"
compatibility_flags = ["nodejs_compat"]
workers_dev = false
preview_urls = false

[vars]
# VAPID_SUBJECT = "mailto:your@email.com"
# VAPID_PUBLIC_KEY = "" # Set after running: bunx web-push generate-vapid-keys
# VAPID_PRIVATE_KEY is set via: wrangler secret put VAPID_PRIVATE_KEY

[assets]
binding = "ASSETS"
directory = ".svelte-kit/cloudflare"

[[d1_databases]]
binding = "DB"
database_name = "messenger-db"
database_id = "D1_DATABASE_ID_PLACEHOLDER"

[durable_objects]
bindings = [
  { name = "SESSION_HUB", class_name = "SessionHub" }
]

[[migrations]]
tag = "v1"
new_sqlite_classes = ["SessionHub"]

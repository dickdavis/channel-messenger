{
	"name": "channel-messenger",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:migrate": "wrangler d1 migrations apply messenger-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply messenger-db --remote",
		"db:reset": "rm -rf .wrangler/state && wrangler d1 migrations apply messenger-db --local",
		"db:query": "wrangler d1 execute messenger-db --local --file",
		"test": "bun test --conditions browser",
		"test:watch": "bun test --conditions browser --watch",
		"lint": "ts-standard",
		"format": "ts-standard --fix"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260317.1",
		"@happy-dom/global-registrator": "^20.8.7",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/svelte": "^5.3.1",
		"@types/bun": "^1.3.11",
		"@types/dompurify": "^3.2.0",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"ts-standard": "^12.0.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.2",
		"ws": "^8.20.0"
	},
	"dependencies": {
		"dompurify": "^3.3.3",
		"marked": "^17.0.5"
	}
}
